# Subscription Manager - Production Environment
# Copy to .env for production

# =============================================================================
# Database
# =============================================================================

DATABASE_URL=postgresql://subscription:changeme@db:5432/subscription_manager
POSTGRES_USER=subscription
POSTGRES_PASSWORD=changeme
POSTGRES_DB=subscription_manager

# =============================================================================
# Application
# =============================================================================

NODE_ENV=production
PORT=3001
BACKEND_PORT=3001
FRONTEND_PORT=3000

# =============================================================================
# Security
# =============================================================================

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_SECRET=your-access-token-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production

# =============================================================================
# Frontend
# =============================================================================

NEXT_PUBLIC_API_URL=http://localhost:3001